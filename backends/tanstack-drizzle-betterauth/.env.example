# Preset: TanStack Start + Drizzle + better-auth
#
# Leave everything unset for zero-config dev (in-memory data + auth, no Docker).
# Set these to move the whole stack onto Postgres + better-auth (production path).

# Postgres connection string. Presence of this flips the app onto Drizzle + the
# better-auth Drizzle adapter (see src/lib/backend.ts).
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/app

# better-auth session-signing secret. REQUIRED in production (the app fails closed
# if NODE_ENV=production and this is unset). Generate: openssl rand -base64 32
# BETTER_AUTH_SECRET=

# Public origin of the app in production (used by better-auth + the browser client).
# BETTER_AUTH_URL=https://app.example.com
# VITE_BETTER_AUTH_URL=https://app.example.com
