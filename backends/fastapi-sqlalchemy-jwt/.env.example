# --- Environment ------------------------------------------------------------
# "development" (default) or "production". In production the service FAILS CLOSED
# (refuses to boot) if AUTH_JWT_SECRET is unset.
APP_ENV=development

# --- Database ----------------------------------------------------------------
# Leave UNSET for zero-config SQLite (./app.db, tables auto-created on startup).
# Set to a Postgres URL for the production path (psycopg driver):
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/dashboard

# --- Auth --------------------------------------------------------------------
# HS256 signing secret for JWTs. Unset in dev → an insecure, clearly-labelled
# fallback is used. REQUIRED in production. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# AUTH_JWT_SECRET=change-me

# Token lifetime in seconds (default 604800 = 7 days).
# AUTH_JWT_TTL_SECONDS=604800

# --- CORS --------------------------------------------------------------------
# Comma-separated frontend origins. Use "*" to allow all (then credentials are
# disabled, per the CORS spec). The frontend proxies server-side, so this only
# matters if a browser hits the API directly. For a specific origin the CORS
# methods/headers are listed explicitly (no wildcard) since credentials are on.
CORS_ORIGINS=http://localhost:3000

# --- Data API token (optional) -----------------------------------------------
# !!! SECURITY: the data API (the /products routes) TRUSTS ITS NETWORK when
# DATA_API_TOKEN is UNSET — anyone who can reach this port can read/write data.
# That is fine for local dev and for a private server-to-server hop, but in
# PRODUCTION set this to a strong random value and have the dashboard frontend
# forward it on every data call:
#     restRepository({ ..., headers: { Authorization: "Bearer <token>" } })
# When set, every /products request must carry `Authorization: Bearer <token>`
# (missing/mismatched → 401). Auth routes (/auth/*) are NOT gated by this.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# DATA_API_TOKEN=change-me
