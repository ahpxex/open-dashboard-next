# --- hono-drizzle-authjs backend preset ---
# Every var is optional for zero-config dev (SQLite + an insecure dev secret).

# Postgres connection string. Unset => SQLite (zero-config). Set => production path.
# DATABASE_URL=postgres://user:pass@localhost:5432/app

# SQLite file path when DATABASE_URL is unset. Use :memory: for an ephemeral DB.
# SQLITE_PATH=./data.db

# Auth.js session-signing secret. REQUIRED in production (the service refuses to
# boot without it when NODE_ENV=production). Generate with: openssl rand -base64 32
# AUTH_SECRET=

# The origin this service is reached at (Auth.js AUTH_URL), read by @hono/auth-js.
# Origin only — the base path is fixed to /api/auth in code, do NOT append it here.
# Optional in dev (derived from the request). Set in prod behind a proxy.
# AUTH_URL=http://localhost:8789

# The dashboard frontend origin — trusted for CORS.
FRONTEND_ORIGIN=http://localhost:3000

# Optional bearer token guarding the /products data routes.
#
# SECURITY: the data API trusts its network when DATA_API_TOKEN is unset. In
# production, set it and have the dashboard frontend forward it
# (restRepository headers: { Authorization: 'Bearer <token>' }). When set, every
# /products request without a matching `Authorization: Bearer <token>` gets 401.
# The /api/auth/* routes are NOT gated by this — they run their own Auth.js flow.
# DATA_API_TOKEN=

# Port this service listens on.
PORT=8789
