# --- hono-prisma-betterauth backend preset ---
# Every var is optional for zero-config dev (SQLite + an insecure dev secret).

# Postgres connection string. Unset => SQLite (zero-config). Set => production path.
# When set, scripts/prisma.ts swaps in prisma/schema.postgres.prisma automatically.
# DATABASE_URL=postgres://user:pass@localhost:5432/app

# SQLite file path when DATABASE_URL is unset. The Prisma client + `prisma db push`
# both resolve it to a file: URL. Use :memory: for an ephemeral DB.
# SQLITE_PATH=./dev.db

# Session-signing secret. REQUIRED in production (the service refuses to boot
# without it when NODE_ENV=production). Generate with: openssl rand -base64 32
# BETTER_AUTH_SECRET=

# The origin this service is reached at (better-auth baseURL). Optional in dev.
# BETTER_AUTH_URL=http://localhost:8788

# The dashboard frontend origin — trusted for CORS + better-auth CSRF.
FRONTEND_ORIGIN=http://localhost:3000

# Port this service listens on (8788 so it does not clash with the Drizzle preset's 8787).
PORT=8788
