# =============================================================================
# Supabase preset — environment variables
# =============================================================================
# These are read by the dashboard FRONTEND wiring (the supabaseRepository + the
# Supabase AuthProvider / auth-client). This preset itself is SQL + config, not a
# long-running service, so it has no server env of its own.
#
# Two sides, two pairs of keys:
#   - SERVER-side (server fns, the AuthProvider, the data adapter): the non-VITE
#     vars below. Never shipped to the browser.
#   - BROWSER-side (the supabase-js browser client in auth-client.ts): the VITE_*
#     vars below. Vite only exposes `import.meta.env.VITE_*` to client code, so
#     the browser client REQUIRES the VITE_ pair — without it the browser client
#     constructs with `undefined` and sign-in breaks at runtime.
# Both pairs point at the same project; keep their values in sync.
#
# LOCAL (supabase start): the CLI prints the URL + anon/service keys on boot.
#   Defaults below are the stable local-dev values printed by `supabase start`.
# HOSTED: copy from your project's Dashboard → Project Settings → API.
# -----------------------------------------------------------------------------

# --- SERVER-side -------------------------------------------------------------

# Project API URL (server). Local default below; hosted looks like
#   https://<project-ref>.supabase.co
SUPABASE_URL=http://127.0.0.1:54321

# Public anon key (server). Safe to expose, but used here SERVER-side: the data
# adapter builds an anon client that carries the *user's* session JWT (forwarded
# from the request cookie), so PostgREST runs as the `authenticated` role and the
# table's RLS policies are actually enforced. RLS gates what it can read/write.
SUPABASE_ANON_KEY=eyJhbGci...your-anon-key

# Service-role key — SERVER-ONLY. Bypasses RLS entirely (superuser-like). Never
# expose to the browser. Reserved for EXPLICITLY-ADMIN server operations that must
# run unconditionally (e.g. cross-tenant maintenance) — NOT the normal data path,
# which uses the anon key + the user's JWT above so RLS applies. Optional: omit it
# if you never need an RLS-bypassing admin client.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key

# --- BROWSER-side (Vite — exposed to client code via import.meta.env) ---------

# Project API URL (browser). Same value as SUPABASE_URL above. REQUIRED: the
# browser auth-client reads `import.meta.env.VITE_SUPABASE_URL`.
VITE_SUPABASE_URL=http://127.0.0.1:54321

# Public anon key (browser). Same value as SUPABASE_ANON_KEY above. REQUIRED: the
# browser auth-client reads `import.meta.env.VITE_SUPABASE_ANON_KEY`. Safe to ship
# to the browser — it is the public anon key, gated by RLS, and carries the user's
# JWT after sign-in. NEVER put the service-role key in a VITE_ var.
VITE_SUPABASE_ANON_KEY=eyJhbGci...your-anon-key
