# =============================================================================
# Supabase preset — environment variables
# =============================================================================
# These are read by the dashboard FRONTEND wiring (the supabaseRepository + the
# Supabase AuthProvider / auth-client). This preset itself is SQL + config, not a
# long-running service, so it has no server env of its own.
#
# LOCAL (supabase start): the CLI prints the URL + anon/service keys on boot.
#   Defaults below are the stable local-dev values printed by `supabase start`.
# HOSTED: copy from your project's Dashboard → Project Settings → API.
# -----------------------------------------------------------------------------

# Project API URL. Local default below; hosted looks like
#   https://<project-ref>.supabase.co
SUPABASE_URL=http://127.0.0.1:54321

# Public anon key — safe to expose to the browser. RLS gates what it can read,
# and it carries the user's JWT after sign-in. Used by both the browser
# auth-client and (with the user's session) the data adapter.
SUPABASE_ANON_KEY=eyJhbGci...your-anon-key

# Service-role key — SERVER-ONLY. Bypasses RLS. Never expose to the browser.
# The frontend data adapter MAY use this on the trusted server-to-server hop
# (the fetch runs inside a server fn that has already called requireUser()).
# If you instead forward the user's JWT to the anon client, you can omit this.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key
