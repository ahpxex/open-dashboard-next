# --- hono-drizzle-betterauth backend preset ---
# Every var is optional for zero-config dev (SQLite + an insecure dev secret).

# Postgres connection string. Unset => SQLite (zero-config). Set => production path.
# DATABASE_URL=postgres://user:pass@localhost:5432/app

# SQLite file path when DATABASE_URL is unset. Use :memory: for an ephemeral DB.
# SQLITE_PATH=./data.db

# Session-signing secret. REQUIRED in production (the service refuses to boot
# without it when NODE_ENV=production). Generate with: openssl rand -base64 32
# BETTER_AUTH_SECRET=

# The origin this service is reached at (better-auth baseURL). Optional in dev.
# BETTER_AUTH_URL=http://localhost:8787

# The dashboard frontend origin — trusted for CORS + better-auth CSRF.
FRONTEND_ORIGIN=http://localhost:3000

# Port this service listens on.
PORT=8787

# Optional bearer token guarding the DATA API (the /products routes only; the
# /api/auth/* routes have their own auth and are never gated by this).
#
# SECURITY: The data API trusts its network when DATA_API_TOKEN is unset — any
# client that can reach this port can read and write /products. In production,
# set it and have the dashboard frontend forward it
# (restRepository headers: { Authorization: 'Bearer <token>' }). When set, every
# /products request must carry `Authorization: Bearer <DATA_API_TOKEN>`; missing
# or mismatched => 401. Generate one with: openssl rand -base64 32
# DATA_API_TOKEN=
