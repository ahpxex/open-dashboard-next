# --- hono-drizzle-authjs backend preset ---
# Every var is optional for zero-config dev (SQLite + an insecure dev secret).

# Postgres connection string. Unset => SQLite (zero-config). Set => production path.
# DATABASE_URL=postgres://user:pass@localhost:5432/app

# SQLite file path when DATABASE_URL is unset. Use :memory: for an ephemeral DB.
# SQLITE_PATH=./data.db

# Auth.js session-signing secret. REQUIRED in production (the service refuses to
# boot without it when NODE_ENV=production). Generate with: openssl rand -base64 32
# AUTH_SECRET=

# The origin this service is reached at, incl. the /api/auth base path (Auth.js
# AUTH_URL). Optional in dev (derived from the request). Set in prod behind a proxy.
# AUTH_URL=http://localhost:8789/api/auth

# The dashboard frontend origin — trusted for CORS.
FRONTEND_ORIGIN=http://localhost:3000

# Port this service listens on.
PORT=8789
